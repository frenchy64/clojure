--- /dev/null
+++ b/test/clojure/test_clojure/compilation/syntax_quote.clj
@@ -0,0 +1,4 @@
+(ns clojure.test-clojure.compilation.syntax-quote)
+
+(defn syntax-quoted-vector []
+  `[[] [] []])
